rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: templates
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-50 chars)
    //   - description: string (optional, 0-200 chars)
    //   - inputStructure: string (required, 0-10000 chars)
    //   - safetyLevel: number (required, 0-100)
    //   - accentColor: string (required, hex format)
    //   - userId: string (required, matches auth.uid)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidTemplate(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 200)) &&
             data.inputStructure is string && data.inputStructure.size() <= 10000 &&
             data.safetyLevel is number && data.safetyLevel >= 0 && data.safetyLevel <= 100 &&
             data.accentColor is string && data.accentColor.matches("^#[0-9a-fA-F]{6}$") &&
             data.userId == request.auth.uid;
    }

    match /templates/{templateId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidTemplate(request.resource.data);
      allow update: if isOwner(resource.data.userId) && isValidTemplate(request.resource.data) && 
                      request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
